generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Wallet {
  id        String   @id @default(uuid())
  ownerName  String
  balance    Decimal    @default(0) @db.Decimal(15, 2)
  
  // Timestamps
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // transaction relations 
  sentTransfers    Transaction[] @relation("sender")
  receivedTransfers Transaction[] @relation("receiver")

  @@map(name: "wallets")
}

model Transaction {
  id          String   @id @default(uuid())
  type        TransactionType
  amount      Decimal  @db.Decimal(15, 2)
  status      TransactionStatus
  reference   String?

  // Timestamps
  createdAt   DateTime   @default(now())

  // wallet relations
  fromWalletId String?
  fromWallet  Wallet? @relation("sender", fields: [fromWalletId], references: [id])

  toWalletId   String
  toWallet    Wallet @relation("receiver", fields: [toWalletId], references: [id])

  @@index([fromWalletId])
  @@index([toWalletId])
  @@map(name: "transactions")
}

enum TransactionType {
  DEPOSIT
  TRANSFER
}

enum TransactionStatus {
  PENDING
  SUCCESSFUL
  FAILED
}